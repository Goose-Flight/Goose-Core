logs/**/*.bin
!logs/.gitkeep
!logs/px4/.gitkeep
!logs/px4/good_flights/.gitkeep
!logs/px4/crashes/.gitkeep
!logs/ardupilot/.gitkeep

# Node
node_modules/
web-ui/

# Environment
.env
.env.*
.claude/

# Internal strategy / business docs (keep local, never commit)
docs/strategy.md
docs/competitor_analysis.md
docs/internal_*.md

# Runtime case storage (local filesystem, never commit)
cases/

# Frontend build output
frontend/dist/
frontend/node_modules/

# Data files
data/*.db
data/*.db-shm
data/*.db-wal
data/*.json

# Logs
logs/*.log
logs/px4/good_flights/
